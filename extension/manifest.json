{
  "manifest_version": 3,
  "name": "Meraki",
  "version": "0.2.0",
  "description": "Highlight and annotate any web page; export to org-mode.",

  "browser_specific_settings": {
    "gecko": {
      "id": "meraki-annotator@meraki.local",
      "strict_min_version": "140.0"
    }
  },

  "permissions": [
    "storage",
    "nativeMessaging"
  ],
  "host_permissions": [
    "<all_urls>"
  ],

  "icons": {
    "48": "icons/meraki-turnedpage-manuscript-48.png",
    "128": "icons/meraki-turnedpage-manuscript-128.png"
  },

  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Meraki",
    "default_icon": {
      "16": "icons/meraki-turnedpage-manuscript-16.png",
      "32": "icons/meraki-turnedpage-manuscript-32.png"
    },
    "theme_icons": [
      { "light": "icons/meraki-turnedpage-manuscript-16.png", "dark": "icons/meraki-turnedpage-ink-16.png", "size": 16 },
      { "light": "icons/meraki-turnedpage-manuscript-32.png", "dark": "icons/meraki-turnedpage-ink-32.png", "size": 32 }
    ]
  },

  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },

  "web_accessible_resources": [
    {
      "resources": ["fonts/*.woff2"],
      "matches": ["<all_urls>"]
    }
  ],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["vendor/browser-polyfill.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
